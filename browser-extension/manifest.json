{
  "manifest_version": 3,
  "name": "Trading Guardian",
  "version": "2.0.0",
  "description": "Locks risk settings and blocks trading outside session hours.",
  "permissions": ["activeTab", "storage", "declarativeNetRequest", "tabs"],
  "host_permissions": ["https://trader.tradovate.com/*", "https://*.tradovateapi.com/*", "https://*.ninjatrader.com/*", "https://app.tradesea.ai/*", "https://*.tradesea.ai/*", "https://topstepx.com/*", "https://*.topstepx.com/*", "https://*.tradingview.com/*", "https://www.tradingview.com/*"],
  "background": { "service_worker": "src/background/service-worker.js", "type": "module" },
  "content_scripts": [
    {
      "matches": ["https://trader.tradovate.com/*"],
      "js": ["src/content/injector.js", "src/content/psychology-coach-main.js", "src/content/tilt-meter.js"],
      "css": ["src/content/block-overlay.css"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://trader.tradovate.com/*"],
      "js": ["src/content/content-script.js", "src/content/psychology-coach.js"],
      "css": [],
      "run_at": "document_start"
    },
    {
      "matches": ["https://app.tradesea.ai/*", "https://topstepx.com/*", "https://*.topstepx.com/*"],
      "js": ["src/content/session-blocker-main.js", "src/content/tilt-meter.js"],
      "css": ["src/content/block-overlay.css"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://app.tradesea.ai/*", "https://topstepx.com/*", "https://*.topstepx.com/*"],
      "js": ["src/content/session-blocker-bridge.js"],
      "css": [],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.tradingview.com/*"],
      "js": ["src/content/tradingview-main.js", "src/content/tilt-meter.js"],
      "css": ["src/content/block-overlay.css"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://www.tradingview.com/*"],
      "js": ["src/content/tradingview-blocker.js"],
      "css": [],
      "run_at": "document_start"
    }
  ],
  "action": { "default_popup": "src/popup/popup.html", "default_icon": { "16": "icons/icon-16.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" } },
  "icons": { "16": "icons/icon-16.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" },
  "declarative_net_request": { "rule_resources": [{ "id": "risk_api_rules", "enabled": false, "path": "src/shared/rules.json" }] },
  "web_accessible_resources": [
    {
      "resources": ["src/content/block-overlay.css"],
      "matches": ["https://trader.tradovate.com/*", "https://app.tradesea.ai/*", "https://topstepx.com/*", "https://*.topstepx.com/*", "https://www.tradingview.com/*"]
    }
  ]
}
